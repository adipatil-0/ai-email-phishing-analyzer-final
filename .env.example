VIRUSTOTAL_API_KEY=your_virustotal_api_key
FLASK_SECRET_KEY=change_this_to_random_string

# Set to true only for local development to enable Flask's interactive
# debugger. NEVER set this to true on a public deployment — it can leak
# stack traces/source paths and in the worst case allow remote code
# execution via the debugger console. Defaults to false either way.
FLASK_DEBUG=true

# --- AI analysis layer ---
# AI_PROVIDER chooses which backend analyze_with_ai() uses:
#   "ollama" (default) - local, free, private, runs on YOUR machine.
#             Needs `ollama serve` running + the model pulled.
#             Works great locally, but does NOT work on Render's free
#             tier (no persistent daemon, not enough RAM).
#   "groq"    - hosted, free tier (no credit card), fast. Used automatically
#             in production via render.yaml. Get a free key at
#             https://console.groq.com/keys
AI_PROVIDER=ollama

# Used when AI_PROVIDER=ollama (defaults shown, only change if running
# Ollama elsewhere or using a different model)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Used when AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Set to false to skip the AI layer entirely regardless of provider
# (e.g. testing the degraded heuristics+enrichment-only scoring path).
AI_ENABLED=true
